{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "batch_tool": true
  },
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 30000
  },
  "compaction": {
    "auto": true,
    "reserved": 12000,
    "tail_turns": 2,
    "preserve_recent_tokens": 12000
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/.next/**",
      "**/target/**"
    ]
  },
  "permission": "ask"
}
